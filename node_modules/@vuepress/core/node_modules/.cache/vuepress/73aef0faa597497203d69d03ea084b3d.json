{"remainingRequest":"/home/qianpz/blog/node_modules/babel-loader/lib/index.js??ref--3-1!/home/qianpz/blog/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/qianpz/blog/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/qianpz/blog/node_modules/vuepress-plugin-code-copy/CodeCopy.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/qianpz/blog/node_modules/vuepress-plugin-code-copy/CodeCopy.vue","mtime":1661190508701},{"path":"/home/qianpz/blog/node_modules/cache-loader/dist/cjs.js","mtime":1661190490337},{"path":"/home/qianpz/blog/node_modules/babel-loader/lib/index.js","mtime":1661190490239},{"path":"/home/qianpz/blog/node_modules/cache-loader/dist/cjs.js","mtime":1661190490337},{"path":"/home/qianpz/blog/node_modules/vue-loader/lib/index.js","mtime":1661190490909}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"mappings":"AAwBA;EACAA;IACAC,cADA;IAEAC,YAFA;IAGAC;MACAC,aADA;MAEAC,aAFA;MAGAC,6BAHA;MAIAC,uBAJA;MAKAC,mBALA;MAMAC;IANA;EAHA,CADA;;EAaAC;IACA;MACAC,cADA;MAEAC,wBAFA;MAGAC;IAHA;EAKA,CAnBA;;EAoBAC;IACAC;MACA;MACAC;MACA;IACA,CALA;;IAMAC;MACA;IACA;;EARA,CApBA;;EA8BAC;IACA;IACA;EACA,CAjCA;;EAkCAC;IACA;IACA;EACA,CArCA;;EAsCAC;IACA;IACAC;MACA;MACA,gBACA;QACAC,0BADA;QAEAC,0BAFA;QAGAC;MAHA,CADA,GAMA,IANA;IAOA,CAXA;;IAYAC;MACA;QACAC,8CACA;UACA;QACA,CAHA,EAIA,QAJA;MAMA,CAPA,MAOA;QACA;QACAC;QACAC;QACAA;QACAD;QACAC;QAEA;MACA;IACA,CA9BA;;IA+BAC;MACAC;;MAEA;QACA;QAEA;QACA;MACA;;MAEA;MACA;QACA;UACA;UACA;QACA;;QACA;MACA,CANA,EAMA,GANA;IAOA;;EAjDA;AAtCA","names":["props","parent","code","options","align","color","backgroundTransition","backgroundColor","successText","staticIcon","data","success","originalBackground","originalTransition","computed","alignStyle","style","iconClass","mounted","beforeDestroy","methods","hexToRgb","r","g","b","copyToClipboard","navigator","document","copyelement","setSuccessTransitions","clearTimeout"],"sourceRoot":"node_modules/vuepress-plugin-code-copy","sources":["CodeCopy.vue"],"sourcesContent":["<template>\n    <div class=\"code-copy\">\n        <svg\n            @click=\"copyToClipboard\"\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            :class=\"iconClass\"\n            :style=\"alignStyle\"\n        >\n            <path fill=\"none\" d=\"M0 0h24v24H0z\" />\n            <path\n                :fill=\"options.color\"\n                d=\"M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm-1 4l6 6v10c0 1.1-.9 2-2 2H7.99C6.89 23 6 22.1 6 21l.01-14c0-1.1.89-2 1.99-2h7zm-1 7h5.5L14 6.5V12z\"\n            />\n        </svg>\n        <span :class=\"success ? 'success' : ''\" :style=\"alignStyle\">\n            {{ options.successText }}\n        </span>\n    </div>\n</template>\n\n<script>\nexport default {\n    props: {\n        parent: Object,\n        code: String,\n        options: {\n            align: String,\n            color: String,\n            backgroundTransition: Boolean,\n            backgroundColor: String,\n            successText: String,\n            staticIcon: Boolean\n        }\n    },\n    data() {\n        return {\n            success: false,\n            originalBackground: null,\n            originalTransition: null\n        }\n    },\n    computed: {\n        alignStyle() {\n            let style = {}\n            style[this.options.align] = '7.5px'\n            return style\n        },\n        iconClass() {\n            return this.options.staticIcon ? '' : 'hover'\n        }\n    },\n    mounted() {\n        this.originalTransition = this.parent.style.transition\n        this.originalBackground = this.parent.style.background\n    },\n    beforeDestroy() {\n        this.parent.style.transition = this.originalTransition\n        this.parent.style.background = this.originalBackground\n    },\n    methods: {\n        // From: https://stackoverflow.com/a/5624139\n        hexToRgb(hex) {\n            let result = /^#?([a-f\\d]{2})([a-f\\d]{2})([a-f\\d]{2})$/i.exec(hex)\n            return result\n                ? {\n                      r: parseInt(result[1], 16),\n                      g: parseInt(result[2], 16),\n                      b: parseInt(result[3], 16)\n                  }\n                : null\n        },\n        copyToClipboard(el) {\n            if (navigator.clipboard) {\n                navigator.clipboard.writeText(this.code).then(\n                    () => {\n                        this.setSuccessTransitions()\n                    },\n                    () => {}\n                )\n            } else {\n                let copyelement = document.createElement('textarea')\n                document.body.appendChild(copyelement)\n                copyelement.value = this.code\n                copyelement.select()\n                document.execCommand('Copy')\n                copyelement.remove()\n\n                this.setSuccessTransitions()\n            }\n        },\n        setSuccessTransitions() {\n            clearTimeout(this.successTimeout)\n\n            if (this.options.backgroundTransition) {\n                this.parent.style.transition = 'background 350ms'\n\n                let color = this.hexToRgb(this.options.backgroundColor)\n                this.parent.style.background = `rgba(${color.r}, ${color.g}, ${color.b}, 0.1)`\n            }\n\n            this.success = true\n            this.successTimeout = setTimeout(() => {\n                if (this.options.backgroundTransition) {\n                    this.parent.style.background = this.originalBackground\n                    this.parent.style.transition = this.originalTransition\n                }\n                this.success = false\n            }, 500)\n        }\n    }\n}\n</script>\n\n<style scoped>\nsvg {\n    position: absolute;\n    right: 7.5px;\n    opacity: 0.75;\n    cursor: pointer;\n}\n\nsvg.hover {\n    opacity: 0;\n}\n\nsvg:hover {\n    opacity: 1 !important;\n}\n\nspan {\n    position: absolute;\n    font-size: 0.85rem;\n    line-height: 0.425rem;\n    right: 50px;\n    opacity: 0;\n    transition: opacity 500ms;\n}\n\n.success {\n    opacity: 1 !important;\n}\n</style>\n"]}]}